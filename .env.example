# --- LLM (Azure OpenAI) ---
# Used for: assess loop, ICP scoring, email generation.
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Enrichment APIs ---
# Hunter.io free tier: 25 domain searches/month (https://hunter.io/api-keys)
HUNTER_API_KEY=
# SerpAPI free tier: 100 searches/month (https://serpapi.com/manage-api-key)
SERPAPI_API_KEY=

# --- Sheets sink ---
# The target spreadsheet ID (from the URL between /d/ and /edit)
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=Leads
# Base64-encoded JSON of a Google service-account key with edit access to the sheet
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Agent behavior ---
MAX_DEEPEN_ROUNDS=2

# --- Webhook security (optional) ---
# If set, requests must include matching `x-webhook-secret` header
WEBHOOK_SECRET=

# --- Logging ---
LOG_LEVEL=info
